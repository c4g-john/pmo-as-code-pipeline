{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pmo-as-code/schema/charter.schema.json",
  "title": "Project Charter frontmatter",
  "type": "object",
  "required": ["kind", "id", "title", "sponsor", "budget", "dates", "status"],
  "additionalProperties": true,
  "properties": {
    "kind": { "const": "charter" },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "description": "Stable, lowercase, hyphenated identifier. Unique across documents/."
    },
    "title": { "type": "string", "minLength": 3 },
    "sponsor": {
      "type": "string",
      "minLength": 2,
      "description": "The accountable individual. A name or handle, not a team."
    },
    "budget": {
      "type": "object",
      "required": ["amount", "currency"],
      "additionalProperties": false,
      "properties": {
        "amount": { "type": "number", "exclusiveMinimum": 0 },
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$" }
      }
    },
    "dates": {
      "type": "object",
      "required": ["created", "target"],
      "additionalProperties": false,
      "properties": {
        "created": { "type": "string", "format": "date" },
        "target": { "type": "string", "format": "date" }
      }
    },
    "status": { "enum": ["draft", "proposed", "approved"] }
  }
}
